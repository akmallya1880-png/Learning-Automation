Linked Question 4:
Count Word Occurrences in a Sentence: Given a string like "my name is Claude Claude", the goal is to print each word along with how many times it appears. "Claude" → 2 times Other words → 1 time each
using System;
using System.Collections.Generic;

class Program
{
    static void Main()
    {
        string input = "my name is Claude Claude";

        string[] words = input.Split(' ');

        Dictionary<string, int> wordCount = new Dictionary<string, int>();

        foreach (string word in words)
        {
            if (wordCount.ContainsKey(word))
            {
                wordCount[word]++;
            }
            else
            {
                wordCount[word] = 1;
            }
        }

        foreach (var item in wordCount)
        {
            Console.WriteLine(item.Key + " → " + item.Value);
        }
    }
}
