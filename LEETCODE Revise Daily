Linked Question 3:
Second smallest Digit in a String: For example, if the input is "claude2403edualc", you need to find and return the digit 2.
using System;
using System.Linq;

class Program
{
    static void Main()
    {
        string input = "claude2403edualc";

        var result = input
            .Where(char.IsDigit)          // take only digits
            .Select(c => c - '0')         // convert char to int
            .Distinct()                   // remove duplicates
            .OrderBy(x => x)              // sort ascending
            .Skip(1)                      // skip smallest
            .FirstOrDefault();            // get second smallest

        Console.WriteLine("Second smallest digit: " + result);
    }
}
