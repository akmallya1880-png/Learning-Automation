using System;
using System.Collections.Generic;
using System.Linq;

class Program
{
    public static void Main()
    {
        int[] a = { 1, 2, 3, 45, 6, 2 };
        int[] b = { 4, 5, 78, 90, 2, 3, 4 };

        // Combine both arrays
        int[] combined = a.Concat(b).ToArray();

        // Count occurrence of each number
        Dictionary<int, int> count = new Dictionary<int, int>();

        foreach (int num in combined)
        {
            if (count.ContainsKey(num))
            {
                count[num]++;
            }
            else
            {
                count[num] = 1;
            }
        }

        // Print result
        foreach (var item in count)
        {
            Console.WriteLine(item.Key + " occurs " + item.Value + " times");
        }
    }
}
